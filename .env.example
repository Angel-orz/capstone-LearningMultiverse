# =============================================================================
# LearningMultiverse — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains sensitive credentials.
# =============================================================================

# --- Learner Identity (optional, for profile isolation) ---
# Set your name to personalize the learning experience.
# If empty, the system will prompt you on first launch.
# LEARNER_NAME=

# --- Claude / LLM Configuration ---
# API key for Claude (required if not using Claude Code's built-in auth).
# CLAUDE_API_KEY=

# --- Data Directory ---
# Where LearningMultiverse stores runtime data (progress, logs, diary).
# Defaults to the project root if not set.
# DATA_DIR=

# --- Security Settings ---
# Enable strict input validation for course names and file paths.
# Default: true. Set to false only for development/testing.
# STRICT_VALIDATION=true

# Enable startup environment check (recommended).
# Default: true.
# ENV_CHECK=true

# --- Feature Flags ---
# Set to "true" to enable spaced repetition review queue.
# ENABLE_REVIEW_QUEUE=true

# Set to "true" to enable the WeChat group chat simulation.
# ENABLE_WECHAT_CHAT=false
